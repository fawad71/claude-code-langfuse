# Add to your project's .env.example (commit) and .env (gitignored).
# claude-code-langfuse-hook reads these at hook runtime. All names use
# the CC_ prefix so they cannot collide with the env vars of any other
# Langfuse-using service in your repo. OS env always wins over what's
# in the file, so direnv / doppler / vault all work.

CC_TRACE_TO_LANGFUSE=true
CC_PROJECT_NAME=karzaty
CC_LANGFUSE_BASE_URL=https://langfuse.internal.example.com

# Team-shared keys for private repos; leave blank and inject via env for
# public repos or per-engineer rotation.
CC_LANGFUSE_PUBLIC_KEY=
CC_LANGFUSE_SECRET_KEY=
